{
  "name": "@panaudia/client",
  "version": "1.0.2",
  "description": "Panaudia client for spatial audio streaming — MOQ and WebRTC transports",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./moq": {
      "import": "./dist/moq/index.js",
      "types": "./dist/moq/index.d.ts"
    },
    "./webrtc": {
      "import": "./dist/webrtc/index.js",
      "types": "./dist/webrtc/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "test:integration": "npx playwright test"
  },
  "keywords": [
    "panaudia",
    "spatial-audio",
    "moq",
    "webrtc",
    "quic",
    "webtransport",
    "opus",
    "real-time",
    "streaming"
  ],
  "author": "Panaudia",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "jose": "^6.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "uuid": "^11.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
